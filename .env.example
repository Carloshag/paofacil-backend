# Configurações do Servidor
PORT=3000

# Banco de Dados na Nuvem (PostgreSQL) - Deixe vazio localmente para usar SQLite
# DATABASE_URL=postgresql://usuario:senha@host:porta/banco?sslmode=require

# Segredos e Segurança
JWT_SECRET=sua_chave_secreta_aqui

# Configurações de SMTP do Provedor de E-mail (Ex: Resend ou Gmail)
# Para Gmail, deixe vazio (usa padrão). Para Resend, use os valores comentados abaixo:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# EMAIL_USER=resend
# EMAIL_PASS=re_sua_chave_resend_aqui
# EMAIL_SENDER="Equipe PãoFácil" <onboarding@resend.dev>

# Configuração Padrão de E-mail (Gmail Fallback)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_aplicativo_aqui
EMAIL_SENDER="Equipe PãoFácil" <seu_email@gmail.com>

# APIs Externas
GOOGLE_MAPS_API_KEY=sua_chave_do_google_maps_aqui
